<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SalaryApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EBEDF5"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="56,*">

        <!-- ── Шапка ── -->
        <Grid
            Grid.Row="0"
            BackgroundColor="#1E1E3C"
            Padding="16,0">
            <Label
                Text="💰 Рассчёт ЗП"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Center"
                HorizontalOptions="Center" />
        </Grid>

        <!-- ── Список карточек ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout
                x:Name="CardsStack"
                Padding="10"
                Spacing="8">

                <!-- Кнопка добавить месяц -->
                <Button
                    x:Name="BtnAddMonth"
                    Text="＋ Добавить месяц"
                    BackgroundColor="#3264C8"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="14"
                    CornerRadius="8"
                    HeightRequest="42"
                    Clicked="BtnAddMonth_Clicked" />

                <!-- Карточки месяцев добавляются сюда динамически -->

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>